<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ViewModel"
             x:Class="View.FixturesListPanel"
             x:DataType="vm:FixturesListPanelViewModel">

  <DockPanel>

    <!-- Header -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource PanelHeader-Bg}"
            Padding="12 9"
            BorderThickness="0 0 0 1"
            BorderBrush="{DynamicResource ThemeBorder0}">
      <TextBlock Text="Fixtures"
                 Foreground="{DynamicResource ThemeText0}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />
    </Border>

    <!-- Fixtures list -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Fixtures}" Margin="0 4 0 4">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:FixtureListItemViewModel">
            <Border Background="{DynamicResource ListItem-Bg}"
                    CornerRadius="4"
                    Margin="8 3 8 3"
                    Padding="10 7">
              <Grid ColumnDefinitions="*,Auto">

                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           Foreground="{DynamicResource ThemeText0}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
