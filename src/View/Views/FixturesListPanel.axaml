<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ViewModel"
             x:Class="View.FixturesListPanel"
             x:DataType="vm:FixturesListPanelViewModel">

  <DockPanel>

    <!-- Header -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource PanelHeader-Bg}"
            Padding="12 9"
            BorderThickness="0 0 0 1"
            BorderBrush="{DynamicResource ThemeBorder0}">
      <TextBlock Text="Fixtures"
                 Foreground="{DynamicResource ThemeText0}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />
    </Border>

    <!-- Fixtures list -->
    <ListBox ItemsSource="{Binding Fixtures}"
             SelectedItem="{Binding SelectedFixture}"
             Background="Transparent"
             BorderThickness="0"
             Padding="0 4 0 4">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:FixtureListItemViewModel">
          <TextBlock Text="{Binding Name}"
                     Foreground="{DynamicResource ThemeText0}"
                     FontSize="12"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </DockPanel>
</UserControl>
