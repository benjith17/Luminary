<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ViewModel"
             x:Class="View.EffectsPanel"
             x:DataType="vm:EffectsPanelViewModel">

  <DockPanel>

    <!-- Header -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource PanelHeader-Bg}"
            Padding="12 9"
            BorderThickness="0 0 0 1"
            BorderBrush="{DynamicResource ThemeBorder0}">
      <TextBlock Text="Effects"
                 Foreground="{DynamicResource ThemeText0}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />
    </Border>

    <!-- Effects list -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Effects}" Margin="0 4 0 4">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:EffectViewModel">
            <Border Background="{DynamicResource ListItem-Bg}"
                    CornerRadius="4"
                    Margin="8 3 8 3"
                    Padding="10 7">
              <Grid ColumnDefinitions="*,Auto">

                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           Foreground="{DynamicResource ThemeText0}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <Button Grid.Column="1"
                        Classes="themed"
                        Command="{Binding AddEffectCommand}"
                        CommandParameter="{Binding}"
                        Width="20" Height="20"
                        Padding="0"
                        FontSize="11"
                        Margin="4 0 0 0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Cursor="Hand">+</Button>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>

</UserControl>
