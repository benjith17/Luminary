<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ViewModel"
             xmlns:views="clr-namespace:View"
             x:Class="View.FixtureEditor"
             x:DataType="vm:FixtureEditorViewModel">

  <UserControl.DataTemplates>
    <DataTemplate x:DataType="vm:DimmerCapabilityViewModel">
      <views:DimmerCapabilityEditor />
    </DataTemplate>
    <DataTemplate x:DataType="vm:ColorCapabilityViewModel">
      <views:ColorCapabilityEditor />
    </DataTemplate>
  </UserControl.DataTemplates>

  <DockPanel>

    <!-- Header -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource PanelHeader-Bg}"
            Padding="12 9"
            BorderThickness="0 0 0 1"
            BorderBrush="{DynamicResource ThemeBorder0}">
      <TextBlock Text="{Binding SelectedFixture.Name, FallbackValue='Fixture Editor'}"
                 Foreground="{DynamicResource ThemeText0}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />
    </Border>

    <!-- Capability editors -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding SelectedFixture.Capabilities}"
                    Margin="12 8" />
    </ScrollViewer>

  </DockPanel>

</UserControl>
