<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ViewModel"
             x:Class="View.FixtureEditor"
             x:DataType="vm:FixtureEditorViewModel">

  <DockPanel>

    <!-- Header -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource PanelHeader-Bg}"
            Padding="12 9"
            BorderThickness="0 0 0 1"
            BorderBrush="{DynamicResource ThemeBorder0}">
      <TextBlock Text="Fixture Editor"
                 Foreground="{DynamicResource ThemeText0}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />
    </Border>

    <!-- Fixtures Editor -->
    
    <Border DockPanel.Dock="Top"
            Padding="12 9"
            BorderThickness="0 0 0 1"
            BorderBrush="{DynamicResource ThemeBorder0}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="{Binding SelectedFixture.Name, FallbackValue='No fixture selected'}"
                   Foreground="{DynamicResource ThemeText0}"
                   FontSize="12"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Border>
  </DockPanel>

</UserControl>
