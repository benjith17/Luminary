<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ViewModel"
             xmlns:views="clr-namespace:View"
             x:Class="View.FixtureEditor"
             x:DataType="vm:FixtureEditorViewModel">

  <UserControl.DataTemplates>
    <DataTemplate x:DataType="vm:DimmerFineCapabilityViewModel">
      <views:DimmerFineCapabilityEditor />
    </DataTemplate>
    <DataTemplate x:DataType="vm:DimmerCapabilityViewModel">
      <views:DimmerCapabilityEditor />
    </DataTemplate>
    <DataTemplate x:DataType="vm:ColorCapabilityViewModel">
      <views:ColorCapabilityEditor />
    </DataTemplate>
    <DataTemplate x:DataType="vm:PanTiltCapabilityViewModel">
      <views:PanTiltCapabilityEditor />
    </DataTemplate>
    <DataTemplate x:DataType="vm:PanTiltFineCapabilityViewModel">
      <views:PanTiltFineCapabilityEditor />
    </DataTemplate>
  </UserControl.DataTemplates>

  <DockPanel>

    <!-- Header -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource PanelHeader-Bg}"
            Padding="12 9"
            BorderThickness="0 0 0 1"
            BorderBrush="{DynamicResource ThemeBorder0}">
      <TextBlock Text="{Binding SelectedFixture.Name, FallbackValue='Fixture Editor'}"
                 Foreground="{DynamicResource ThemeText0}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />
    </Border>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="4" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Capability editors -->
      <ScrollViewer Grid.Row="0"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding SelectedFixture.Capabilities}"
                      Margin="12 8">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>
      </ScrollViewer>

      <GridSplitter Classes="themed horizontal" Grid.Row="1" />

      <!-- Effects -->
      <Border Grid.Row="2"
              BorderThickness="0 1 0 0"
              BorderBrush="{DynamicResource ThemeBorder0}">
      </Border>

    </Grid>

  </DockPanel>

</UserControl>
